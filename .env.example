# ── AI (Free) ──────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey (free, no card)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database (Free) ────────────────────────────────────────────────
# Get from: https://supabase.com → New Project → Settings → Database
# Use the "URI" connection string (Transaction pooler mode)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ── App Config ─────────────────────────────────────────────────────
# Any random string you choose, used to protect admin POST endpoints
ADMIN_TOKEN=choose_any_random_string_here

# ── Frontend ───────────────────────────────────────────────────────
# For local dev use: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
