# ── Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NASA ADS (https://ui.adsabs.harvard.edu/user/settings/token) ───
NASA_ADS_TOKEN=your_ads_token_here

# ── Semantic Scholar (optional, raises rate limit) ──────────────────
SEMANTIC_SCHOLAR_API_KEY=

# ── PostgreSQL ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://plasma:plasma@localhost:5432/plasma_db

# ── Object Storage for figures (Cloudflare R2 or AWS S3) ───────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=plasma-figures
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
